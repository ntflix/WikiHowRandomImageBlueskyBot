# Bluesky credentials (use an app password)
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Scheduler settings
BOT_CRON=0 13 * * *
BOT_TIMEZONE=UTC

# Runtime settings
BOT_DATABASE_PATH=.state/bot_state.sqlite3
BOT_DEDUP_WINDOW_HOURS=168
BOT_MAX_ARTICLE_ATTEMPTS=6
BOT_DRY_RUN=false
BOT_HTTP_TIMEOUT_SECONDS=20
BOT_USER_AGENT=wikihow-random-image-bluesky-bot/0.1.0

# Optional OpenAI-compatible alt text generation
ALT_GEN_ENABLED=false
ALT_GEN_ENDPOINT=https://your-openai-compatible-endpoint.tld/v1/responses
ALT_GEN_API_KEY=
ALT_GEN_MODEL=gpt-5.4-nano
ALT_GEN_TIMEOUT_SECONDS=20
